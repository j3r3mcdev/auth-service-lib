  "author": "Jérémy",
  "license": "MIT",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/validator": "^13.15.10",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "bcrypt": "^5.1.1"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "validator": "^13.15.35"
